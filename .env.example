VMS_DATA_DIR=./data
VMS_SESSION_TIMEOUT_S=300
VMS_ANALYSIS_FPS=2
VMS_YOLO_MODEL=yolov8n.pt
VMS_YOLO_DEVICE=auto

# Local database used by Docker Compose.
POSTGRES_DB=avm
POSTGRES_USER=avm
POSTGRES_PASSWORD=troque-esta-senha-local
# Optional for non-Docker local runs. If empty, the app uses data/store.json.
# VMS_DATABASE_URL=postgresql://avm:troque-esta-senha-local@127.0.0.1:5432/avm

# Auth
VMS_SESSION_SECRET=change-me-to-a-long-random-value
VMS_ADMIN_TOKEN=change-me-to-a-long-random-value
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional local-only development bypass. Do not use in demos.
# VMS_DEV_AUTH_EMAIL=dev@example.com

# Email alerts
VMS_SMTP_HOST=smtp.gmail.com
VMS_SMTP_PORT=587
VMS_SMTP_USER=seu-email@gmail.com
VMS_SMTP_PASSWORD=senha-de-app-do-google
VMS_SMTP_FROM=seu-email@gmail.com
VMS_SMTP_TLS=1
